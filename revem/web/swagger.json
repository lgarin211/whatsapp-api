{
    "openapi": "3.0.0",
    "info": {
        "title": "WhatsApp API (Revem)",
        "description": "API for sending messages and media via WhatsApp Web JS",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local server"
        }
    ],
    "paths": {
        "/send-message": {
            "post": {
                "summary": "Send a text message",
                "description": "Sends a text message to a specific phone number.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "number": {
                                        "type": "string",
                                        "description": "The recipient's phone number, exact contact name, or exact group name."
                                    },
                                    "message": {
                                        "type": "string",
                                        "description": "The text message to send"
                                    }
                                },
                                "required": [
                                    "number",
                                    "message"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Message sent!"
                    },
                    "400": {
                        "description": "Bad Request (Missing fields)"
                    },
                    "422": {
                        "description": "Number is not registered on WhatsApp"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    },
                    "503": {
                        "description": "WhatsApp client is not ready"
                    }
                }
            }
        },
        "/send-media": {
            "post": {
                "summary": "Send media via URL",
                "description": "Sends a media file (image, video, document) from a given URL to a specific phone number.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "number": {
                                        "type": "string",
                                        "description": "The recipient's phone number"
                                    },
                                    "file": {
                                        "type": "string",
                                        "description": "The URL of the media file to send"
                                    },
                                    "caption": {
                                        "type": "string",
                                        "description": "Optional text caption for the media"
                                    }
                                },
                                "required": [
                                    "number",
                                    "file"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Media sent!"
                    },
                    "400": {
                        "description": "Bad Request (Missing fields)"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    },
                    "503": {
                        "description": "WhatsApp client is not ready"
                    }
                }
            }
        },
        "/send-local-media": {
            "post": {
                "summary": "Send media via local file upload",
                "description": "Uploads a media file (image, video, document) and sends it to a specific phone number.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "number": {
                                        "type": "string",
                                        "description": "The recipient's phone number, exact contact name, or exact group name."
                                    },
                                    "file": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "The actual file to upload and send"
                                    },
                                    "caption": {
                                        "type": "string",
                                        "description": "Optional text caption for the media"
                                    }
                                },
                                "required": [
                                    "number",
                                    "file"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Local media sent!"
                    },
                    "400": {
                        "description": "Bad Request (Missing fields)"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    },
                    "503": {
                        "description": "WhatsApp client is not ready"
                    }
                }
            }
        },
        "/clear-message": {
            "post": {
                "summary": "Clear chat history",
                "description": "Clears the chat history with a specific phone number, contact name, or group name.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "number": {
                                        "type": "string",
                                        "description": "The phone number, contact name, or group name to clear chat with"
                                    }
                                },
                                "required": [
                                    "number"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Chat cleared"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    },
                    "503": {
                        "description": "WhatsApp client is not ready"
                    }
                }
            }
        }
    }
}