{
  "name": "whatsapp-api",
  "version": "1.0.0",
  "description": "Whatsapp api by Ngekoding",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:dev": "nodemon app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:linux": "pkg app.js --targets node18-linux-x64 --out-path bin",
    "build:win": "pkg app.js --targets node18-win-x64 --out-path bin"
  },
  "keywords": [
    "whatsapp-api",
    "node.js"
  ],
  "author": "Nur Muhammad",
  "license": "MIT",
  "dependencies": {
    "axios": "^0.20.0",
    "express": "^4.17.1",
    "express-fileupload": "^1.2.0",
    "express-validator": "^6.9.2",
    "http": "0.0.1-security",
    "mime-types": "^2.1.32",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "2.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "^1.34.4"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "nodemon": "^2.0.22",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "index.html",
      "index-multiple-account.html",
      "helpers/**/*",
      "modular/**/*",
      "media/**/*",
      "swagger.js"
    ]
  }
}